<% layout("/layouts/boilerplate1.ejs") %>

<div class="row mt-3">
    <div class="col-12 col-md-5 offset-md-3">
        <br><br><br>
        <h2>New Password</h2>
        <form action="/reset-password" method="POST" novalidate class="needs-validation">
        
            <div class="md-3">
                <label for="password" class="form-lable">Password:</label>
                <input name="password" 
                    type="password"
                    class="form-control" 
                    id="password"
                    required>
                      
            </div><br>
            <button class="login" type="submit">Reset New Password</button>
            
        </form>
    
    </div>
</div>
