<% layout("/layouts/boilerplatelogin.ejs") %>

<div class="row mt-3">
    <div class="col-12 col-md-5 offset-md-3">
        <br><br><br>
        <h4 class="loginsignup">
            <span class="inline-block">Sign Up &gt;</span>
            <a href="/login" class="inline-block">Login</a> /
            <a href="/listings" class="inline-block">Home</a>
        </h4>
        <form action="/signup" method="POST" novalidate class="needs-validation">
            <div class="md-3">
                <label for="username" class="form-lable">Username</label>
                <input name="username" 
                    type="text"
                    class="form-control" 
                    id="username"
                    required>
                    <div class="invalid-feedback">
                        Enter Username
                      </div>      
            </div>
            <div class="md-3">
                <label for="email" class="form-lable">Email</label>
                <input name="email" 
                    type="email"
                    class="form-control" 
                    id="email"
                    required>
                    <div class="invalid-feedback">
                        Enter <b>Valid</b> Email
                      </div>      
            </div>
            <div class="md-3">
                <label for="password" class="form-lable">Password</label>
                <input name="password" 
                    type="password"
                    class="form-control" 
                    id="password"
                    required>
                    <div class="invalid-feedback">
                        Enter <b>Valid</b> password
                      </div>      
            </div><br>
            <button class="login">SignUp</button>
        </form>
    </div>
</div>