<% layout("/layouts/boilerplate1.ejs") %>
<form action="/listings/<%= listing._id %>?_method=POST" method="POST" >  
  <div class="row mt-3">
    <div class="col-12 col-md-8 offset-md-3">
      <br><br>
      <h4>Booking for</h4>
      <% if (listing.rooms > 0) { %> 
        <div class="md-3 col-md-8">
          <input type="text" name="booking[listingid]" class="form-control" value="<%= listing._id %>" readonly hidden></div>
          
        <div class="md-3 col-md-8">
        <input type="text" name="booking[hotelname]" class="form-control" value="<%= listing.title %>" readonly></div>
        <div class="md-3 col-md-8">
          <input type="text" name="booking[image]" class="form-control" value="<%= listing.image.url %>" readonly hidden></div>
          
        <div class="row md-3">
          <div class="md-3 col-md-4">
            <label for="location" class="form-lable">City</label>
        <input type="text"  name="booking[location]"  value="<%= listing.location %>" class="form-control" required  readonly>
          </div>
          <div class="md-3 col-md-4">
            <label for="country" class="form-lable">Country</label>
            <input type="text"  name="booking[country]"  value="<%= listing.country %>" class="form-control" required  readonly>
        
        </div>
        </div>
        <div class="md-3 col-md-8">
        <label for="name" class="form-lable">UserName</label>
          <input type="text" id="name" name="booking[name]" class="form-control" required value="<%= currentUser.username.toUpperCase()  %>"></div>
          
          <div class="row md-3">
            <div class="md-3 col-md-4">
              <label for="checkin" class="form-lable">Checkin 11:00 AM</label>
          <input type="date" id="checkin" name="booking[checkin]" class="form-control" required >
            </div>
            <div class="md-3 col-md-4">
              <label for="checkout" class="form-lable">CheckOut 11:00 AM</label>
              <input type="date" id="checkout" name="booking[checkout]" class="form-control" required >
          
          </div>
        </div>
        <div class="row md-3">
          <div class="md-3 col-md-4">
            <label for="noofrooms" class="form-lable">Number Of Rooms</label>
              <input type="number" id="noofrooms" class="form-control" name="booking[noofrooms]" min="1" max="<%= listing.rooms %>" placeholder="Enter number of rooms" required>
            </div>
            <div class="md-3 col-md-4">
              <label for="totalPrice" class="form-lable">Total Price With GST</label>
              <input type="totalPrice" id="totalPrice" name="booking[totalPrice]" class="form-control" value="<%= listing.price * 1.5 %>" readonly><%= listing.price * 1.5 %>/night with GST<br>
              </div>
        </div>

          
        <p><b>Available Rooms : <%= listing.rooms %></b></p>

          <button class="button"> <i class="fa-solid fa-bookmark"></i> Book Now</button><br>
          <% } else { %>
            <input type="text" name="booking[hotelname]" class="form-control" value="<%= listing.title %>" readonly>
            <h3><b>Sorry, no rooms available!</b>
        <% } %>
       
      
  
    
  </div>
</div>
</form>



<script>
   document.addEventListener("DOMContentLoaded", function () {
    let checkin = document.getElementById("checkin");
    let checkout = document.getElementById("checkout");
    let noofrooms = document.getElementById("noofrooms");
    let totalPrice = document.getElementById("totalPrice");
    let pricePerNight = "<%= listing.price %>"; // Get price from backend

    function calculateTotalPrice() {
        let checkinDate = new Date(checkin.value);
        let checkoutDate = new Date(checkout.value);
        let numberOfRooms = parseInt(noofrooms.value) || 1;

        // Calculat e number of nights
        let timeDifference = checkoutDate - checkinDate;
        let nights = Math.max(1, timeDifference / (1000 * 3600 * 24)); // Ensure at least 1 night

        // Calculate total price
        let total = numberOfRooms * pricePerNight * nights * 1.5 ; // Including 18% GST
        totalPrice.value = total.toFixed(2); // Format to 2 decimal places
    }

    // Add event listeners
    checkin.addEventListener("change", calculateTotalPrice);
    checkout.addEventListener("change", calculateTotalPrice);
    noofrooms.addEventListener("input", calculateTotalPrice);
});

</script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
      let today = new Date().toISOString().split("T")[0]; // Get today's date in YYYY-MM-DD format

      document.getElementById("checkin").setAttribute("min", today);
      document.getElementById("checkout").setAttribute("min", today);

      document.getElementById("checkin").addEventListener("change", function () {
          document.getElementById("checkout").setAttribute("min", this.value);
      });
  });
</script>